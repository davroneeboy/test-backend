# =============================================================
#  Шаблон .env — скопируй в .env и заполни своими значениями
#  Сгенерировать SECRET_KEY:
#    python manage.py shell -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# =============================================================

# Django core
# Оборачивай в одинарные кавычки — ключ может содержать $, # и другие спецсимволы
SECRET_KEY='замени-на-случайную-строку'
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CORS: разрешённые origins для фронтенда (через запятую)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Throttling (брутфорс логина)
LOGIN_THROTTLE_RATE=5/min

# Логирование
DJANGO_LOG_LEVEL=WARNING

# Sentry (оставь пустым чтобы отключить)
SENTRY_DSN=
